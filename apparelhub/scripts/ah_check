#!/usr/bin/env bash
# ah_check — verify APPARELHUB_API_KEY is set AND accepted by the
# ApparelHub Agent API before starting a multi-step workflow.
#
# Distinguishes three failure modes a workflow shouldn't try to recover
# from blindly:
#   exit 0 — key is set and the platform accepts it.
#   exit 2 — key is not set in the environment.
#   exit 3 — key is set but the platform rejected it (401/403), or the
#            request failed at the network level.
#
# Value-add: surfaces auth issues BEFORE you've burned 30 minutes
# generating designs and mockups whose products you can't actually
# create. Not for prompt suppression — your runtime SHOULD prompt the
# first time it expands $APPARELHUB_API_KEY; that's the safety control
# working correctly. Approve in context.
#
# The canonical API host is hard-pinned (see SECURITY.md §2c). There is
# no runtime override. Contributors testing against dev should fork and
# edit the constant below.

set -euo pipefail

# Hard-pinned canonical host. See SECURITY.md §2c. No env-var override.
API_BASE="https://api.apparelhub.ai"
HUB_HOST="apparelhub.ai"

if [ -z "${APPARELHUB_API_KEY:-}" ]; then
    echo "ah_check: APPARELHUB_API_KEY not set in environment" >&2
    echo "         Generate one at https://${HUB_HOST}/developer/api-keys" >&2
    echo "         Then: export APPARELHUB_API_KEY=<your-key>" >&2
    exit 2
fi

# Hit a lightweight authed endpoint to verify the key works. /store is
# small and always returns at least the user's default store, so it's a
# reliable round-trip probe.
HTTP_CODE=$(curl -sS -o /dev/null -w "%{http_code}" \
    "${API_BASE}/agents/v1/store" \
    -H "x-api-key: $APPARELHUB_API_KEY")

case "$HTTP_CODE" in
    200)
        # Mask the key for safe display (first 7 + last 4)
        if [ ${#APPARELHUB_API_KEY} -ge 12 ]; then
            MASKED="${APPARELHUB_API_KEY:0:7}...${APPARELHUB_API_KEY: -4}"
        else
            MASKED="(set)"
        fi
        echo "ah_check: ok (key $MASKED, target $API_BASE)"
        exit 0
        ;;
    401|403)
        echo "ah_check: key set but rejected by the platform (HTTP $HTTP_CODE)" >&2
        echo "         Verify at https://${HUB_HOST}/developer/api-keys" >&2
        exit 3
        ;;
    000)
        echo "ah_check: network failure reaching $API_BASE" >&2
        echo "         Check connectivity and try again." >&2
        exit 3
        ;;
    *)
        echo "ah_check: unexpected response (HTTP $HTTP_CODE) from $API_BASE" >&2
        echo "         The platform may be having issues. Try again in a minute." >&2
        exit 3
        ;;
esac
