#!/usr/bin/env bash
# ah_check — verify APPARELHUB_API_KEY is set AND valid against the live API.
#
# Run this as the FIRST call of any session that uses the apparelhub skill.
# Distinguishes three cases:
#   - Not set:        exit 2 with instructions to generate one
#   - Set but bad:    exit 3 (401/403 from the platform — revoked or wrong env)
#   - Set and works:  exit 0 with a masked-key confirmation line
#
# The agent's visible command line is just `ah_check` — no $VAR expansion, so
# Claude Code's simple_expansion check doesn't fire and the allowlist matches
# cleanly.

set -euo pipefail

if [ -z "${APPARELHUB_API_KEY:-}" ]; then
    echo "ah_check: APPARELHUB_API_KEY not set in environment" >&2
    echo "         Generate one at https://apparelhub.ai/developer/api-keys" >&2
    echo "         Then: export APPARELHUB_API_KEY=ah_xxx..." >&2
    exit 2
fi

# Hit a lightweight authed endpoint to verify the key works. /store is small
# and always returns at least the user's default store, so it's a reliable
# round-trip probe.
HTTP_CODE=$(curl -sS -o /dev/null -w "%{http_code}" \
    "https://api.apparelhub.ai/agents/v1/store" \
    -H "x-api-key: $APPARELHUB_API_KEY")

case "$HTTP_CODE" in
    200)
        # Mask the key for safe display (first 7 + last 4)
        if [ ${#APPARELHUB_API_KEY} -ge 12 ]; then
            MASKED="${APPARELHUB_API_KEY:0:7}...${APPARELHUB_API_KEY: -4}"
        else
            MASKED="(set)"
        fi
        echo "ah_check: ok (key $MASKED)"
        exit 0
        ;;
    401|403)
        echo "ah_check: key set but rejected by the platform (HTTP $HTTP_CODE)" >&2
        echo "         The key may be revoked, expired, or from the wrong environment." >&2
        echo "         Verify at https://apparelhub.ai/developer/api-keys" >&2
        exit 3
        ;;
    000)
        echo "ah_check: network failure reaching api.apparelhub.ai" >&2
        echo "         Check connectivity and try again." >&2
        exit 3
        ;;
    *)
        echo "ah_check: unexpected response (HTTP $HTTP_CODE) from api.apparelhub.ai" >&2
        echo "         The platform may be having issues. Try again in a minute." >&2
        exit 3
        ;;
esac
