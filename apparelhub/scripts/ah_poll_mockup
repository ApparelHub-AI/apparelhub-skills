#!/usr/bin/env python3
"""
ah_poll_mockup — block until a Printful/Printify mockup job is fully
ready (status=completed AND at least one preview_url ingested).

Value-add: the mockup pipeline has TWO completion gates, not one. The
job reports `status=completed` as soon as the provider's mockup
generator finishes its task. The per-preview `preview_url` field
(populated when we mirror the mockup from the provider's CDN to our S3)
lands separately and can lag the `completed` status by 20+ minutes. A
naive poll that stops at `completed` will then try to use a preview row
with `preview_url=NULL` and end up with broken product cards.

This script encodes the two-phase state machine + transient HTTP retry
semantics so callers don't have to. It is NOT a prompt-suppression
wrapper; your runtime SHOULD prompt when it expands $APPARELHUB_API_KEY
the first time. Approve in context.

Usage:
    ah_poll_mockup <provider_uuid> <job_uuid>
                   [--timeout SECONDS]              default 1800 (30 min)
                   [--interval SECONDS]             default 8
                   [--out PATH]                     default /tmp/preview_job.json
                   [--min-ready N]                  default 1
                   [--max-transient-errors N]      default 5

Exit codes:
    0: job completed AND >= min-ready previews have preview_url
    1: timeout, job failed, auth error, or too many consecutive transient errors
    2: APPARELHUB_API_KEY not set, or bad CLI args

Canonical host: https://api.apparelhub.ai is hard-pinned (see
SECURITY.md §2c). No env-var override. Contributors testing against dev
should fork and edit the constant below.

Transient error handling: the job-status endpoint occasionally returns
HTTP 5xx (most commonly 504 from the gateway when our backend is
mid-S3-ingestion or the provider upstream is slow). These are EXPECTED
during polling because the job is still progressing. The script treats
the following as transient and keeps polling:
  - HTTP 502 (Bad Gateway)
  - HTTP 503 (Service Unavailable)
  - HTTP 504 (Gateway Timeout)
  - HTTP 429 (Too Many Requests)
  - URLError (TCP connect failure, DNS, etc.)
Up to --max-transient-errors consecutive failures (default 5) before
bailing. Counter resets to 0 on any successful poll. 4xx (other than
429) and other 5xx codes are still fatal.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import time
import urllib.error
import urllib.request

# Hard-pinned canonical host. See SECURITY.md §2c. No env-var override.
API_BASE = "https://api.apparelhub.ai"
HUB_HOST = "apparelhub.ai"


def fetch_job(provider_uuid: str, job_uuid: str, api_key: str) -> dict:
    url = (
        f"{API_BASE}/agents/v1/merchandise/product/preview/"
        f"{provider_uuid}/job/{job_uuid}"
    )
    req = urllib.request.Request(url, headers={"x-api-key": api_key})
    with urllib.request.urlopen(req, timeout=30) as resp:
        body = resp.read().decode("utf-8")
    return json.loads(body)


def count_ready_previews(payload: dict) -> tuple[int, int]:
    """Return (ready_count, total_count) for the previews[] array.

    Defensively handles the previews array living at top-level OR nested
    under a `data`/`job` key.
    """
    candidates = (
        payload.get("previews"),
        (payload.get("data") or {}).get("previews") if isinstance(payload.get("data"), dict) else None,
        (payload.get("job") or {}).get("previews") if isinstance(payload.get("job"), dict) else None,
    )
    previews = next((c for c in candidates if isinstance(c, list)), [])
    total = len(previews)
    ready = sum(1 for p in previews if isinstance(p, dict) and p.get("preview_url"))
    return ready, total


def main() -> int:
    ap = argparse.ArgumentParser(prog="ah_poll_mockup", description=__doc__)
    ap.add_argument("provider_uuid")
    ap.add_argument("job_uuid")
    ap.add_argument("--timeout", type=int, default=1800)
    ap.add_argument("--interval", type=int, default=8)
    ap.add_argument("--out", default="/tmp/preview_job.json")
    ap.add_argument("--min-ready", type=int, default=1)
    ap.add_argument("--max-transient-errors", type=int, default=5,
                    help="consecutive transient errors (504/502/503/429/URLError) to "
                         "tolerate before bailing. Counter resets on any success. "
                         "Default 5.")
    args = ap.parse_args()

    api_key = os.environ.get("APPARELHUB_API_KEY")
    if not api_key:
        sys.stderr.write(
            "ah_poll_mockup: APPARELHUB_API_KEY not set in environment\n"
            f"                 Generate one at https://{HUB_HOST}/developer/api-keys\n"
            "                 Then: export APPARELHUB_API_KEY=<your-key>\n"
        )
        return 2

    start = time.monotonic()
    poll_n = 0
    last_payload: dict | None = None
    last_status: str | None = None
    transient_errors_in_a_row = 0

    # HTTP status codes that indicate a transient upstream/gateway issue:
    # the job is still progressing on the platform side, just retry.
    TRANSIENT_HTTP_CODES = {502, 503, 504, 429}

    while True:
        poll_n += 1
        elapsed = int(time.monotonic() - start)
        try:
            payload = fetch_job(args.provider_uuid, args.job_uuid, api_key)
        except urllib.error.HTTPError as e:
            if e.code in TRANSIENT_HTTP_CODES:
                transient_errors_in_a_row += 1
                if transient_errors_in_a_row > args.max_transient_errors:
                    sys.stderr.write(
                        f"ah_poll_mockup: {transient_errors_in_a_row} consecutive transient "
                        f"errors (last was HTTP {e.code}); exceeded --max-transient-errors "
                        f"{args.max_transient_errors}. Bailing.\n"
                    )
                    return 1
                if elapsed >= args.timeout:
                    sys.stderr.write(
                        f"ah_poll_mockup: timeout after {args.timeout}s during transient "
                        f"HTTP {e.code} retry loop.\n"
                    )
                    return 1
                print(
                    f"poll {poll_n} ({elapsed}s): transient HTTP {e.code} "
                    f"(retry {transient_errors_in_a_row}/{args.max_transient_errors}, "
                    f"sleeping {args.interval}s)",
                    flush=True,
                )
                time.sleep(args.interval)
                continue
            # Non-transient HTTP error: bail.
            sys.stderr.write(
                f"ah_poll_mockup: HTTP {e.code} from job endpoint "
                f"(provider={args.provider_uuid}, job={args.job_uuid})\n"
            )
            if e.code in (401, 403):
                sys.stderr.write(
                    f"                 Key rejected against {API_BASE}, so make sure the key matches THIS env.\n"
                    f"                 Verify at https://{HUB_HOST}/developer/api-keys\n"
                )
            return 1
        except urllib.error.URLError as e:
            # Network-layer failure (DNS, TCP, TLS). Treat as transient.
            transient_errors_in_a_row += 1
            if transient_errors_in_a_row > args.max_transient_errors:
                sys.stderr.write(
                    f"ah_poll_mockup: {transient_errors_in_a_row} consecutive network "
                    f"failures (last: {e.reason}); exceeded --max-transient-errors "
                    f"{args.max_transient_errors}. Bailing.\n"
                )
                return 1
            if elapsed >= args.timeout:
                sys.stderr.write(
                    f"ah_poll_mockup: timeout after {args.timeout}s during network "
                    f"retry loop ({e.reason}).\n"
                )
                return 1
            print(
                f"poll {poll_n} ({elapsed}s): network failure ({e.reason}) "
                f"(retry {transient_errors_in_a_row}/{args.max_transient_errors}, "
                f"sleeping {args.interval}s)",
                flush=True,
            )
            time.sleep(args.interval)
            continue
        except json.JSONDecodeError:
            sys.stderr.write("ah_poll_mockup: non-JSON response from job endpoint\n")
            return 1

        # Successful response: reset the transient counter
        transient_errors_in_a_row = 0
        last_payload = payload
        # Persist on every poll so the agent can inspect partial state if
        # something goes wrong mid-loop.
        try:
            with open(args.out, "w") as fh:
                json.dump(payload, fh, indent=2)
        except OSError as e:
            sys.stderr.write(f"ah_poll_mockup: could not write --out {args.out}: {e}\n")
            return 1

        status = payload.get("status") or "unknown"
        ready, total = count_ready_previews(payload)
        last_status = status

        line = f"poll {poll_n} ({elapsed}s): status={status}"
        if total or ready:
            line += f", previews_ready={ready}/{total}"
        print(line, flush=True)

        if status == "failed":
            sys.stderr.write("ah_poll_mockup: provider reports job failed\n")
            return 1

        if status == "completed" and ready >= args.min_ready:
            print(
                f"ah_poll_mockup: done in {elapsed}s, "
                f"{ready}/{total} previews ready, response saved to {args.out}",
                flush=True,
            )
            return 0

        if elapsed >= args.timeout:
            sys.stderr.write(
                f"ah_poll_mockup: timeout after {args.timeout}s "
                f"(last status={last_status}, response saved to {args.out})\n"
            )
            return 1

        time.sleep(args.interval)


if __name__ == "__main__":
    sys.exit(main())
