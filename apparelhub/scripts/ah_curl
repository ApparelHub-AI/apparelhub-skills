#!/usr/bin/env bash
# ah_curl — agent-API curl wrapper.
#
# Reads APPARELHUB_API_KEY from the environment so the AGENT's command line
# contains NO shell expansion ($VAR / ${VAR} / $(...)). Claude Code's
# "simple_expansion" check otherwise prompts on every call regardless of how
# permissive the allowlist is. This wrapper exists ONLY to keep the visible
# command line allowlist-clean.
#
# Usage:
#   ah_curl METHOD PATH_OR_URL [extra curl args...]
#
# Examples:
#   ah_curl GET /agents/v1/store
#   ah_curl POST /agents/v1/images/generate -d '{"prompt":"...","source":"Nano Banana"}'
#   ah_curl POST /agents/v1/images/generated/abc-123/transform -F image=@/tmp/design.png
#   ah_curl PATCH /agents/v1/product/abc-123 -d '{"display_image":"https://..."}'
#   ah_curl DELETE /agents/v1/product/abc-123
#
# Argument shape:
#   - METHOD is GET / POST / PATCH / PUT / DELETE (uppercase, no -X prefix).
#   - PATH_OR_URL is either:
#       * an absolute path starting with /  (e.g. /agents/v1/store)
#         -> prefixed with https://api.apparelhub.ai
#       * a full URL (https://... or http://...) -> used as-is
#   - Any remaining args are passed through to curl unchanged. Useful flags:
#       -d '{"k":"v"}'        JSON body (default Content-Type: application/json)
#       -d @/tmp/payload.json JSON body from file
#       -F image=@/tmp/x.png  multipart file upload (we'll skip the default
#                             JSON Content-Type so curl can set the boundary)
#       -o /tmp/out.bin       save response to file (e.g. downloading mockups)
#
# Authoritative env:
#   APPARELHUB_API_KEY  — required. Generate at apparelhub.ai/developer/api-keys
#
# Exit codes:
#   0   curl succeeded (HTTP code printed inside the body; this wrapper does
#       not interpret status — caller parses the response as needed)
#   2   APPARELHUB_API_KEY not set, or missing METHOD/PATH_OR_URL arg
#   *   curl's own exit code on transport failure

set -euo pipefail

if [ -z "${APPARELHUB_API_KEY:-}" ]; then
    echo "ah_curl: APPARELHUB_API_KEY not set in environment" >&2
    echo "         Generate one at https://apparelhub.ai/developer/api-keys" >&2
    echo "         Then: export APPARELHUB_API_KEY=ah_xxx..." >&2
    exit 2
fi

METHOD=${1:?usage: ah_curl METHOD PATH_OR_URL [curl args...]}
shift
PATH_OR_URL=${1:?usage: ah_curl METHOD PATH_OR_URL [curl args...]}
shift

# Resolve to a full URL
case "$PATH_OR_URL" in
    https://*|http://*) URL=$PATH_OR_URL ;;
    /*)                 URL="https://api.apparelhub.ai$PATH_OR_URL" ;;
    *)                  URL="https://api.apparelhub.ai/$PATH_OR_URL" ;;
esac

# Build the headers array
HEADERS=(-H "x-api-key: $APPARELHUB_API_KEY")

# If caller is doing a multipart upload (-F / --form), don't preset
# Content-Type — let curl auto-set it with the right boundary. Otherwise
# default to JSON, which is what 95%+ of the agent API calls expect.
HAS_F=0
for arg in "$@"; do
    case "$arg" in
        -F|--form|-F*|--form=*) HAS_F=1; break ;;
    esac
done
if [ $HAS_F -eq 0 ]; then
    HEADERS+=(-H "Content-Type: application/json")
fi

exec curl -sS -X "$METHOD" "$URL" "${HEADERS[@]}" "$@"
